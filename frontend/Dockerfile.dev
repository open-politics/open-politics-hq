# syntax=docker/dockerfile:1.7
FROM oven/bun:alpine

WORKDIR /app

# Install deps first so source edits don't invalidate the install layer.
# bun.lock is the current lockfile; package-lock.json is kept around for openapi tooling.
COPY package.json bun.lock* package-lock.json* ./
RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile

# Source comes after deps so rebuilds skip reinstall.
COPY . .

EXPOSE 3000

CMD ["bun", "run", "dev", "--turbo"]
