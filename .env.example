# Domain
# This would be set to the production domain with an env var on deployment
DOMAIN=localhost # e.g. open-politics.org

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME='HQ'

# Frontend (Next.js) — host-side port. Container always binds 3000 internally.
FRONTEND_PORT=3000

# Backend
BACKEND_PORT=8022
# Address uvicorn binds to inside the backend container. 0.0.0.0 is correct
# for the default bridge network (docker's network isolation does the work).
# The hardened-network setup mode flips this to 127.0.0.1; setup.sh manages it.
BACKEND_BIND_HOST=0.0.0.0
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:3000,http://open-politics.org,https://open-politics.org,https://open-politics.org:80,https://open-politics.org:443"
SECRET_KEY=changeThis

# Worker counts (compose only; helm scales via replicas)
BACKEND_WORKERS=4
CELERY_CONCURRENCY=4

# Optional services to start, comma-separated: minio, ollama, searxng, nominatim, caddy.
# Empty = lean core only. setup.sh manages this per chosen preset.
# COMPOSE_PROFILES=

# Caddy (reverse proxy + auto-TLS for production VPS deployments).
# Only used when the `caddy` profile is active. ACME_EMAIL is the contact
# Let's Encrypt uses for cert expiry notifications. DOMAIN above must point
# to this host (an A-record matching the server's public IP).
# ACME_EMAIL=

# Encryption key for storing user API keys securely (REQUIRED in production)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_MASTER_KEY=changethis
# Decrypt-only legacy keys used ONLY during key rotation (comma-separated).
# Never used to encrypt. Set the old key here, rotate, then remove. See: ./setup.sh rotate --fernet
# ENCRYPTION_MASTER_KEY_FALLBACKS=

FIRST_SUPERUSER=changeThis
FIRST_SUPERUSER_PASSWORD=changeThis
USERS_OPEN_REGISTRATION=True

# Example Remote S3 Configuration
# MINIO_ENDPOINT=nbg1.your-objectstorage.com (Hetzner)
# MINIO_HOST=
# MINIO_PORT=
# MINIO_ROOT_USER=xxx
# MINIO_ROOT_PASSWORD=xxx
# MINIO_BUCKET_NAME=yyy
# MINIO_REGION=eu-central
# MINIO_ACCESS_KEY=xxx
# MINIO_SECRET_KEY=xxx
# MINIO_SECURE=true
# MINIO_USE_SSL=true

OLLAMA_BASE_URL=http://ollama:11434

# Storage provider: "minio" | "s3" | "local_fs"
STORAGE_PROVIDER_TYPE=local_fs

# OCR provider: "tesseract" | "ocrmypdf" | "ollama"
# OCR_PROVIDER_TYPE=tesseract
# OLLAMA_OCR_MODEL=llava



# Local filesystem storage (when STORAGE_PROVIDER_TYPE=local_fs)
# Two paths: HOST is where bytes actually live on your machine (bind source).
# BASE is where the backend sees them inside the container — stable, rarely changed.
# Default HOST is repo-relative so a fresh clone works without sudo. Point it at
# any absolute path (e.g. /mnt/data/hq) when you outgrow the repo dir.
# Extra read-only datasets can be added via compose.override.yml mounts under BASE,
# e.g. /host/dataset_collection:/data/storage/datasets:ro
LOCAL_STORAGE_HOST_PATH=./.store/local_fs
LOCAL_STORAGE_BASE_PATH=/data/storage

# Directory import: whitelist of paths users can import from (comma-separated)
# Container-side paths. Default points at the managed area inside BASE.
ALLOWED_IMPORT_PATHS=/data/storage/datasets,/data/storage/managed

# S3-compatible storage/ MiniO (Files, Documents uploaded or ingested into workspace)
MINIO_ENDPOINT=minio:9000
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=app_user
MINIO_ROOT_PASSWORD=app_user_password
MINIO_BUCKET_NAME=webapp-dev-user-documents
MINIO_REGION=
MINIO_ACCESS_KEY=app_user
MINIO_SECRET_KEY=app_user_password
MINIO_USE_SSL=false

REDIS_HOST=redis      
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

## Optional Redis override
# @REDIS_URL=redis://my-redis-host.aws.com:6379/0
# or rediss://... for TLS
# or redis://user:pass@host:port/db for auth

# ────────────────────────────── Geocoding Configuration ──────────────────────────────
# Public geocoding uses local Nominatim with auto-fallback to public API (no config needed)
# User agent for public API requests (required by Nominatim usage policy)
GEOCODING_USER_AGENT=OpenPoliticsHQ/1.0

# Local Nominatim Container (for compose/kubernetes deployments)
NOMINATIM_BASE_URL=http://nominatim:8080

# For Europe detailed (10 min import, address-level, needs your maschine to suvive a 12-14gb peak memory workload)
NOMINATIM_PBF_URL=https://download.geofabrik.de/europe-latest.osm.pbf
NOMINATIM_IMPORT_STYLE=admin

# For world coarse (2h import, city/district-level) - DEFAULT
# NOMINATIM_PBF_URL=https://planet.openstreetmap.org/pbf/planet-latest.osm.pbf
# NOMINATIM_IMPORT_STYLE=admin

# Optional: Mapbox API token (only for authenticated users via frontend)
# Users can provide their own API keys at runtime - this is just a fallback
MAPBOX_ACCESS_TOKEN=
# ─────────────────────────────────────────────────────────────────────────────────────

# Emails
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=True
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_NAME=${PROJECT_NAME}
EMAILS_FROM_EMAIL=info@example.com
SMTP_SSL=False
REQUIRE_EMAIL_VERIFICATION=false

## Example Remote Postgres Connection
# POSTGRES_SERVER=xx.xx.xx.xxx
# POSTGRES_PORT=6432
# POSTGRES_DB=opp_app_users_dev
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=xyz
# POSTGRES_SSL_MODE=require

# Postgres (local)
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=opp_app_users
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeThis

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# ────────────────────────────── AI Provider Keys ──────────────────────────────
# System-level API keys. When set, these keys are used as the fallback (step 3)
# in the resolver's credential chain: runtime keys → user stored keys → system keys.
# Leave blank if users should bring their own keys via the frontend.
OPENAI_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=
# JINA_API_KEY=
# VOYAGE_API_KEY=

# Optional: override base URLs (e.g. for proxies or self-hosted endpoints)
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# MISTRAL_BASE_URL=https://api.mistral.ai
# VOYAGE_BASE_URL=https://api.voyageai.com/v1

# ────────────────────────────── Provider Access Control ───────────────────────
# Format: PROVIDER_ACCESS_{CAPABILITY}_{provider_key}={level}   (case-insensitive)
# Capabilities: language, embedding, ocr, geocoding, storage, scraping, web_search
# Levels: "all" (any infospace owner) | "superuser" (superuser owners only) | "none" (blocked)
#
# DEFAULT BEHAVIOR when a key is UNSET (this is the real behavior, no magic):
#   - Keyless local providers (ollama, tesseract, nominatim local, local_fs,
#     searxng, newspaper4k) just work — they need no API key, so there is
#     nothing to gate.
#   - Keyed cloud providers (openai, anthropic, jina, voyage, tavily, ...) are
#     NOT shared. The system env key above is never handed to a user's resolve()
#     unless an explicit grant below allows it. Users bring their own key (BYOK).
#
# A user's own stored API key always works regardless of these settings — these
# only gate whether the deployment's system env key is shared.
# Legacy: PROVIDER_ACCESS_LLM_* is auto-rewritten to PROVIDER_ACCESS_LANGUAGE_* (warns).
#
# Examples:
#
# --- Self-hosted: system OpenAI for everyone, Anthropic for superusers only ---
# PROVIDER_ACCESS_LANGUAGE_openai=all
# PROVIDER_ACCESS_LANGUAGE_anthropic=superuser
# PROVIDER_ACCESS_EMBEDDING_openai=all
#
# --- Cloud: share system keys with all authenticated users ---
# PROVIDER_ACCESS_LANGUAGE_openai=all
# PROVIDER_ACCESS_LANGUAGE_anthropic=all
# PROVIDER_ACCESS_WEB_SEARCH_tavily=all
#
# --- Explicitly block a provider in this deployment ---
# PROVIDER_ACCESS_LANGUAGE_mistral=none
#
# --- Locked-down (default): nothing set — every cloud provider is BYOK ---
# ─────────────────────────────────────────────────────────────────────────────

# Annotation Processing Configuration
DEFAULT_ANNOTATION_CONCURRENCY=5
MAX_ANNOTATION_CONCURRENCY=20

# Discourse SSO
DISCOURSE_CONNECT_ENABLED=
DISCOURSE_CONNECT_SECRET=changeThis
DISCOURSE_CONNECT_URL= # e.g. https://forum.open-politics.org


PROCESS_CONTENT_RATE_LIMIT=50/s
PDF_MAX_PAGES=0
STORAGE_BROWSE_MAX_COUNT_FILES=5000


# Enrichers: comma-separated names, "*" for all, empty = none.
# Values: hash, ocr, geocoding, language_detection, quality_score, embedding
# ENABLED_ENRICHERS=*
ENABLED_ENRICHERS=""
